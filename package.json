{
  "name": "ikuma-theme",
  "displayName": "ikuma-theme",
  "description": "VS Code theme for personal use.",
  "publisher": "46ki75",
  "version": "0.0.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/46ki75/ikuma-theme"
  },
  "type": "module",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Themes"
  ],
  "scripts": {
    "prebuild": "rimraf dist && mkdir -p dist",
    "build": "vsce package --out dist/",
    "build:theme": "node scripts/index.ts",
    "build:theme:watch": "node --watch --watch-path=scripts scripts/index.ts"
  },
  "contributes": {
    "themes": [
      {
        "label": "Ikuma Theme Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/ikuma-theme-dark-color-theme.json"
      },
      {
        "label": "Ikuma Theme Light",
        "uiTheme": "vs",
        "path": "./themes/ikuma-theme-light-color-theme.json"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  }
}
