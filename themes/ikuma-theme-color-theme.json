{
  "name": "ikuma-theme",
  "type": "dark",
  "colors": {
    "foreground": "#f1e9da",
    "textLink.foreground": "#ad9f7d",
    "textLink.activeForeground": "#ddcfb5",
    "list.activeSelectionBackground": "#453f39",
    "list.activeSelectionForeground": "#ddcfb5",
    "focusBorder": "#5c5346",
    "input.background": "#454c58",
    "chat.linesAddedForeground": "#59b57cc5",
    "chat.linesRemovedForeground": "#c56565c7",
    "editor.background": "#393e46",
    "editor.foreground": "#d9dce4",
    "activityBar.background": "#242629",
    "activityBar.foreground": "#ddcfb5",
    "activityBar.activeBackground": "#31353a",
    "activityBar.activeBorder": "#ddcfb5",
    "sideBarTitle.foreground": "#b0b5be",
    "sideBar.background": "#31353a",
    "tab.activeBorderTop": "#ad9f7d",
    "editorGroupHeader.tabsBackground": "#31353a",
    "panel.background": "#393e46",
    "button.background": "#ad9f7d",
    "button.foreground": "#d9dce4",
    "panelTitle.inactiveForeground": "#867b64",
    "panelTitle.activeForeground": "#ddcfb5",
    "menu.background": "#393e46",
    "menu.foreground": "#f1e9da",
    "scrollbarSlider.background": "#867b64",
    "activityBarBadge.background": "#63564a",
    "activityBarBadge.foreground": "#f1e9da",
    "statusBar.background": "#242629",
    "statusBar.noFolderBackground": "#242629",
    "statusBar.debuggingBackground": "#242629",
    "statusBar.foreground": "#ddcfb5",
    "quickInput.background": "#31353a",
    "quickInput.foreground": "#ddcfb5",
    "quickInputList.focusBackground": "#5c5346",
    "editorBracketHighlight.foreground1": "#868e9c",
    "editorBracketHighlight.foreground2": "#967a62",
    "editorBracketHighlight.foreground3": "#867b64",
    "editorBracketHighlight.foreground4": "#868e9c",
    "editorBracketHighlight.foreground5": "#967a62",
    "editorBracketHighlight.foreground6": "#867b64",
    "editorBracketHighlight.unexpectedBracket.foreground": "#c56565",
    "editorBracketMatch.background": "#ad9f7d40",
    "editorBracketMatch.border": "#ad9f7d",
    "editorOverviewRuler.bracketMatchForeground": "#867b64"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#868e9c",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c0a361"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#ccaea2"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#d48b70"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#cdb57b"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "variable.other.readwrite.alias",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#d8cbb7"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#a38c78"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key",
        "entity.name.tag.yaml",
        "entity.name.tag.toml",
        "support.type.property-name.toml",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#dcd1ba"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#c56565"
      }
    },
    {
      "scope": [
        "variable",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#d9dce4"
      }
    }
  ],
  "semanticTokenColors": {
    "comment": {
      "foreground": "#868e9c",
      "fontStyle": "italic"
    },
    "keyword": "#c0a361",
    "operator": "#a38c78",
    "string": "#ccaea2",
    "number": "#d48b70",
    "regexp": "#ccaea2",
    "variable": "#d9dce4",
    "variable.readonly": "#ad9f7d",
    "parameter": "#d9dce4",
    "property": "#dcd1ba",
    "function": "#cdb57b",
    "method": "#cdb57b",
    "macro": "#cdb57b",
    "decorator": "#cdb57b",
    "event": "#cdb57b",
    "label": "#dcd1ba",
    "class": "#d8cbb7",
    "interface": "#d8cbb7",
    "enum": "#d8cbb7",
    "struct": "#d8cbb7",
    "type": "#d8cbb7",
    "typeParameter": "#d8cbb7",
    "namespace": "#d8cbb7",
    "enumMember": "#d48b70",
    "*.defaultLibrary": "#ddcfb5",
    "variable.readonly.defaultLibrary": "#ad9f7d",
    "*.async": {
      "fontStyle": "italic"
    },
    "*.deprecated": {
      "fontStyle": "strikethrough"
    }
  }
}
