{
  "name": "ikuma-theme",
  "type": "dark",
  "colors": {
    "textLink.foreground": "#ad9f7d",
    "textLink.activeForeground": "#ddcfb5",
    "list.activeSelectionBackground": "#453f39",
    "list.activeSelectionForeground": "#ddcfb5",
    "focusBorder": "#5c5346",
    "input.background": "#454c58",
    "chat.linesAddedForeground": "#59b57cc5",
    "chat.linesRemovedForeground": "#c56565c7",
    "editor.background": "#393e46",
    "editor.foreground": "#d9dce4",
    "activityBar.background": "#242629",
    "activityBar.foreground": "#ddcfb5",
    "activityBar.activeBackground": "#31353a",
    "activityBar.activeBorder": "#ddcfb5",
    "sideBarTitle.foreground": "#b0b5be",
    "sideBar.background": "#31353a",
    "tab.activeBorderTop": "#ad9f7d",
    "editorGroupHeader.tabsBackground": "#31353a",
    "panel.background": "#393e46",
    "button.background": "#ad9f7d",
    "button.foreground": "#d9dce4",
    "panelTitle.inactiveForeground": "#867b64",
    "panelTitle.activeForeground": "#ddcfb5",
    "menu.background": "#393e46",
    "menu.foreground": "#f1e9da",
    "scrollbarSlider.background": "#867b64",
    "activityBarBadge.background": "#63564a",
    "activityBarBadge.foreground": "#f1e9da",
    "statusBar.background": "#242629",
    "statusBar.noFolderBackground": "#242629",
    "statusBar.debuggingBackground": "#242629",
    "statusBar.foreground": "#ddcfb5",
    "quickInput.background": "#31353a",
    "quickInput.foreground": "#ddcfb5",
    "quickInputList.focusBackground": "#5c5346"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#546e7a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c792ea"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#c3e88d"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#f78c6c"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#82aaff"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#ffcb6b"
      }
    },
    {
      "scope": [
        "punctuation",
        "keyword.operator",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#cdb57b"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f07178"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#c56565"
      }
    },
    {
      "scope": [
        "variable",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#d9dce4"
      }
    }
  ]
}
