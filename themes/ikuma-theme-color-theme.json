    "statusBar.border": "#00000000",
    "titleBar.activeBackground": "#393e46",
    "titleBar.activeForeground": "#ece4d4",
    "titleBar.inactiveBackground": "#393e46",
    "titleBar.inactiveForeground": "#aba294",
