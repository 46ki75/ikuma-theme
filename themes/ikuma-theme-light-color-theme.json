  "semanticTokenColors": {
    "comment": { "foreground": "#9a9789", "fontStyle": "italic" },
    "keyword": "#7a6010",
    "operator": "#4a443a",
    "string": "#5e7036",
    "number": "#9c5c4a",
    "regexp": "#2c7a72",
    "variable": "#4a443a",
    "variable.readonly": "#9c5c4a",
    "parameter": "#4a443a",
    "property": "#7a5e2c",
    "function": "#3e7548",
    "method": "#3e7548",
    "macro": "#3e7548",
    "decorator": "#3e7548",
    "event": "#3e7548",
    "label": "#7a5e2c",
    "class": "#7e6536",
    "interface": "#7e6536",
    "enum": "#7e6536",
    "struct": "#7e6536",
    "type": "#7e6536",
    "typeParameter": "#7e6536",
    "namespace": "#7e6536",
    "enumMember": "#9c5c4a",
    "*.defaultLibrary": "#54451f",
    "variable.readonly.defaultLibrary": "#9c5c4a",
    "*.async": { "fontStyle": "italic" },
    "*.deprecated": { "fontStyle": "strikethrough" }
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#9a9789", "fontStyle": "italic" }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.definition.tag",
        "punctuation.definition.typeparameters",
        "meta.brace",
        "delimiter"
      ],
      "settings": { "foreground": "#9a9789" }
    },
    {
      "scope": ["keyword", "storage", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#7a6010" }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.relational",
        "keyword.operator.type"
      ],
      "settings": { "foreground": "#4a443a" }
    },
    {
      "scope": ["string", "constant.other.symbol", "attribute.value"],
      "settings": { "foreground": "#5e7036" }
    },
    {
      "scope": ["punctuation.definition.string"],
      "settings": { "foreground": "#5e703677" }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.character.escape",
        "number"
      ],
      "settings": { "foreground": "#9c5c4a" }
    },
    {
      "scope": ["constant.language.boolean"],
      "settings": { "foreground": "#9c5c4a" }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": { "foreground": "#3e7548" }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "support.class.component",
        "type.identifier"
      ],
      "settings": { "foreground": "#7e6536" }
    },
    {
      "scope": ["variable", "identifier", "variable.parameter"],
      "settings": { "foreground": "#4a443a" }
    },
    {
      "scope": [
        "variable.other.readwrite.alias",
        "variable.other.enummember",
        "constant",
        "entity.name.constant",
        "variable.language"
      ],
      "settings": { "foreground": "#9c5c4a" }
    },
    {
      "scope": ["entity.name.tag", "tag.html"],
      "settings": { "foreground": "#7a6010" }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name",
        "meta.object-literal.key",
        "meta.property-name",
        "entity.name.tag.yaml",
        "entity.name.tag.toml",
        "support.type.property-name.toml",
        "attribute.name",
        "property"
      ],
      "settings": { "foreground": "#7a5e2c" }
    },
    {
      "scope": ["source.regexp", "string.regexp"],
      "settings": { "foreground": "#2c7a72" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#a04545" }
    },
    {
      "scope": "invalid.deprecated",
      "settings": { "foreground": "#a04545", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.heading", "markup.heading entity.name"],
      "settings": { "foreground": "#7a6a45", "fontStyle": "bold" }
    },
    {
      "scope": "markup.italic",
      "settings": { "foreground": "#4a443a", "fontStyle": "italic" }
    },
    {
      "scope": "markup.bold",
      "settings": { "foreground": "#4a443a", "fontStyle": "bold" }
    },
    { "scope": "markup.quote", "settings": { "foreground": "#7e6536" } },
    { "scope": "markup.raw", "settings": { "foreground": "#7a6a45" } },
    {
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file",
        "punctuation.definition.deleted"
      ],
      "settings": { "foreground": "#a04545" }
    },
    {
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file",
        "punctuation.definition.inserted"
      ],
      "settings": { "foreground": "#2e8f53" }
    },
    {
      "scope": ["markup.changed", "punctuation.definition.changed"],
      "settings": { "foreground": "#54451f" }
    },
    {
      "scope": [
        "markup.underline.link.markdown",
        "markup.underline.link.image.markdown"
      ],
      "settings": { "foreground": "#6e6759", "fontStyle": "underline" }
    }
  ]
}
